---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import AssetDetail from "../../components/AssetDetail";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toToolAsset } from "../../lib/vault";

export async function getStaticPaths() {
  const tools = (await getCollection("tools")) as CollectionEntry<"tools">[];
  return tools.map((tool) => ({ params: { id: tool.slug }, props: { tool } }));
}

const tool = Astro.props.tool as CollectionEntry<"tools">;
const asset = toToolAsset(tool);
const { Content } = await render(tool);
---

<BaseLayout title={`${asset.title} - Asset Vault`} description={asset.summary}>
  <main class="ff-detail-shell" data-pagefind-body>
    <AssetDetail asset={asset} client:load />
    <article class="ff-prose ff-notes">
      <Content />
    </article>
  </main>
</BaseLayout>
