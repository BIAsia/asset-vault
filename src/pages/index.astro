---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import VaultHome from "../components/VaultHome";
import BaseLayout from "../layouts/BaseLayout.astro";
import { createVaultIndex } from "../lib/vault";

const tools = (await getCollection("tools")) as CollectionEntry<"tools">[];
const vault = createVaultIndex(tools);
---

<BaseLayout title="Asset Vault" description="Search saved creative tools, demos, references, and libraries.">
  <VaultHome vault={vault} client:load />
</BaseLayout>
