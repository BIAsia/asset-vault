{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@scripts/*": ["scripts/*"]
    },
    "types": ["node"]
  },
  "include": [".astro/types.d.ts", "src", "scripts", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"]
}
